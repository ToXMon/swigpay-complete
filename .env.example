# ============================================================
# SwigPay — Environment Variables
# Copy to .env and fill with real values
# NEVER commit .env — only .env.example
# ============================================================

# ---- Solana ----
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Recommended: replace with Helius/QuickNode devnet to avoid rate limits
# SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ---- Server Wallet (receives x402 payments) ----
# Generate: solana-keygen new --outfile server-wallet.json --no-bip39-passphrase
# Get base58 key: pnpm tsx scripts/setup-wallets.ts
SERVER_WALLET_PRIVATE_KEY_BASE58=YOUR_SERVER_PRIVATE_KEY_BASE58
SERVER_WALLET_ADDRESS=YOUR_SERVER_PUBLIC_KEY

# ---- Agent Wallet (makes x402 payments via Squads spending limit) ----
# Generate: solana-keygen new --outfile agent-wallet.json --no-bip39-passphrase
AGENT_PRIVATE_KEY_BASE58=YOUR_AGENT_PRIVATE_KEY_BASE58
AGENT_ADDRESS=YOUR_AGENT_PUBLIC_KEY

# ---- Human Operator Wallet (Squads configAuthority + override) ----
# Generate: solana-keygen new --outfile human-wallet.json --no-bip39-passphrase
HUMAN_PRIVATE_KEY_BASE58=YOUR_HUMAN_PRIVATE_KEY_BASE58
HUMAN_ADDRESS=YOUR_HUMAN_PUBLIC_KEY

# ---- Squads v4 (filled after running scripts/provision-agent.ts) ----
SQUADS_MULTISIG_PDA=
SQUADS_VAULT_PDA=
SQUADS_SPENDING_LIMIT_PDA=
SQUADS_DAILY_LIMIT_USDC=1.0
SQUADS_PER_TX_LIMIT_USDC=0.01
SQUADS_APPROVAL_THRESHOLD_USDC=0.5

# ---- x402 Protocol ----
FACILITATOR_URL=https://x402.org/facilitator
MCP_PRICE_PER_CALL_USD=0.001

# ---- Ports ----
MCP_SERVER_PORT=4022
DASHBOARD_PORT=3000

# ---- Database ----
DB_PATH=./swigpay.db

# ============================================================
# QUICKSTART:
# 1. Install Solana CLI: sh -c "$(curl -sSfL https://release.solana.com/stable/install)"
# 2. Configure devnet: solana config set --url devnet
# 3. Generate wallets: pnpm tsx scripts/setup-wallets.ts
# 4. Airdrop SOL:
#      solana airdrop 2 <SERVER_ADDRESS>
#      solana airdrop 2 <AGENT_ADDRESS>
#      solana airdrop 2 <HUMAN_ADDRESS>
# 5. Get devnet USDC (for AGENT wallet):
#      Visit https://faucet.circle.com → USDC → Solana Devnet → paste AGENT_ADDRESS
#      Get 20 USDC (enough for 20,000 x $0.001 tool calls)
# 6. Fill in private keys above from setup-wallets.ts output
# 7. Provision Squads wallet: pnpm tsx scripts/provision-agent.ts
# 8. Update SQUADS_* vars above with output
# ============================================================
